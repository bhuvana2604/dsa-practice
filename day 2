#birthday cake candles
def birthdayCakeCandles(candles):
    c= max(candles)
    n = candles.count(c)
    return n

#time conversion
def timeConversion(s):
    # Write your code here
    hour = int(s[:2])
    if s[-2:]=="AM":
        if hour == 12:
            hour =0
    else:
        if hour!=12:
            hour+=12
    return f"{hour:02d}"+s[2:-2]

#grading students
def gradingStudents(grades):
    # Write your code here
    r=[]
    for i in grades:
        if i<38:
            r.append(i)
        else:
            next_multiple = ((i//5)+1)*5
            if next_multiple - i<3:
                r.append(next_multiple)
            else:
                r.append(i)
    return r  

#breaking the records
def breakingRecords(scores):
    n = len(scores)
    min = scores[0]
    max =scores[0]
    min_count = 0
    max_count = 0
    for i in range(1,n):
        if scores[i]<min:
            min = scores[i]
            min_count+=1   
        elif scores[i]>max:
            max=scores[i]
            max_count+=1
    return [max_count,min_count]        